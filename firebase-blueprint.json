{
  "entities": {
    "VoiceGeneration": {
      "title": "Voice Generation",
      "description": "A generated voice record with its metadata and audio reference.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The input text." },
        "emotion": { "type": "string", "description": "Detected or selected emotion." },
        "voiceName": { "type": "string", "description": "Name of the voice used." },
        "audioData": { "type": "string", "description": "Base64 encoded audio string." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "userId": { "type": "string", "description": "ID of the user who generated it." }
      },
      "required": ["text", "emotion", "voiceName", "audioData", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/history/{generationId}": {
      "schema": "VoiceGeneration",
      "description": "Collection of generated voice clips for history."
    }
  }
}
